classDiagram
    class Owner {
        +string firstName
        +string lastName
        +string email
        +Scheduler scheduler
        +List~Pet~ pets
        +addPet(pet: Pet): void
        +addScheduler(scheduler: Scheduler): void
        +generatePlan(): Plan
    }

    class Pet {
        +string name
        +string type
        +List~Task~ tasks
        +addTask(task: Task): void
    }

    class Task {
        +TaskType type
        +int frequency
        +int durationMinutes
        +Priority priority
    }

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class TaskType {
        <<enumeration>>
        WALKS
        FEEDING
        BATHROOM_BREAKS
        MENTAL_PLAY
        GROOMING
        MEDICATIONS
        VET_APPOINTMENT
    }

    class TimeSlot {
        +datetime startTime
        +datetime endTime
    }

    class Scheduler {
        +List~TimeSlot~ timeSlots
        +buildPlan(pets: List~Pet~): Plan
    }

    class Plan {
        +int id
        +Map~string_List~Task~~ taskListByPet
        +string explanation
    }

    Owner "1" --> "*" Pet : owns
    Pet --> Task : has
    Owner --> Scheduler : has
    Scheduler --> TimeSlot : uses
    Owner --> Plan : generates
    Plan --> Task : contains
